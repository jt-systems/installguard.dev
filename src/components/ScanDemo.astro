---
/**
 * ScanDemo.astro — fixed sample of `installguard scan` output styled
 * with inline-coloured spans. Built as a template-literal string and
 * passed through Terminal's `body` prop so newlines survive Astro's
 * whitespace normalisation.
 */
import Terminal from "./Terminal.astro";
import { dim, err, fg, joinTerminalLines, mid, ok, prompt, warn } from "./terminalAnsi";

const body = joinTerminalLines([
  prompt("installguard scan"),
  `${ok("  ✓ 1,273 packages cleared")}`,
  `${dim("    policy v1 · cache hit 99.8% · 1.84s")}`,
  ``,
  `${err("  ✗ block")}     ${fg("react-toolkit-utils@2.0.0")}`,
  `              ${dim("name-squat         ")}${mid("distance-1 from `react-toolkit` (38M dl/wk)")}`,
  `              ${dim("suspicious-script  ")}${mid("postinstall executes base64-decoded payload")}`,
  ``,
  `${err("  ✗ block")}     ${fg("@acme/auth@4.1.7")}`,
  `              ${dim("publisher-change   ")}${mid("new maintainer account, registered 6h ago")}`,
  ``,
  `${warn("  ⚠ warn")}      ${fg("color-utils@1.4.2")}`,
  `              ${dim("release-age        ")}${mid("published 18h ago (24h cooling-off)")}`,
  ``,
  `${dim("  Summary  ")}${ok("1273 allow")}${dim(" · ")}${warn("1 warn")}${dim(" · ")}${err("2 block")}`,
  `${dim("$")} ${dim("echo $?")}`,
  `${fg("1")}`,
]);
---

<Terminal title="~/work/api · installguard scan" body={body} />
