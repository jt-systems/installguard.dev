---
/**
 * Terminal.astro — chrome-style terminal frame with traffic-light dots.
 * Used on the homepage so we can render multi-line code blocks with
 * inline ANSI-style coloured spans without MDX's paragraph rules
 * eating the contents.
 */
interface Props {
  title?: string;
}
const { title } = Astro.props;
---

<div class="overflow-hidden rounded-lg border border-slate-800 bg-slate-950 shadow-2xl shadow-emerald-500/5">
  <div class="flex items-center gap-2 border-b border-slate-800 bg-slate-900/60 px-4 py-2">
    <span class="size-3 rounded-full bg-red-500/70"></span>
    <span class="size-3 rounded-full bg-amber-500/70"></span>
    <span class="size-3 rounded-full bg-emerald-500/70"></span>
    {title && <span class="ml-3 font-mono text-xs text-slate-500">{title}</span>}
  </div>
  <pre class="overflow-x-auto p-5 font-mono text-sm leading-relaxed"><code><slot /></code></pre>
</div>
