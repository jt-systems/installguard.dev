---
/**
 * QuickStart.astro — three-step install/scan/CI snippet for the
 * homepage. Built as a template-literal HTML body for the same
 * whitespace-preservation reason as ScanDemo.
 */
import Terminal from "./Terminal.astro";

const ansi = (tone: string, text: string) =>
  `<span class="ig-ansi ig-ansi--${tone}">${text}</span>`;
const dim = (t: string) => ansi("dim", t);
const fg = (t: string) => ansi("fg", t);

const body = [
  `${dim("# 1. Install")}`,
  `${fg("brew install jt-systems/installguard/installguard")}`,
  ``,
  `${dim("# 2. Scan any supported repo")}`,
  `${fg("cd ~/work/your-project")}`,
  `${fg("installguard scan")}`,
  ``,
  `${dim("# 3. Wire it into CI (exit code 1 on block)")}`,
  `${fg("installguard ci --summary-file summary.json")}`,
].join("\n");
---

<Terminal title="macOS · Linux · WSL" body={body} />
